# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NUNCA vai para o git.

# Brevo (ex-Sendinblue) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# ID da lista de contatos criada no painel Brevo
BREVO_LIST_ID=123

# ID do template de e-mail de boas-vindas criado no painel Brevo
BREVO_TEMPLATE_ID=1

# E-mail remetente (deve ter domínio verificado com SPF + DKIM)
BREVO_SENDER_EMAIL=diario@melfiore.com
BREVO_SENDER_NAME=MELFIORE
